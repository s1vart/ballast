# Copy this file to `.env` and fill in your values. NEVER commit .env.
# Get these from the Plaid dashboard: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# sandbox = fake test banks (free) | production = your real banks
PLAID_ENV=sandbox

# Must EXACTLY match `android.package` in app/app.json AND the
# "Allowed Android package names" list in the Plaid dashboard.
ANDROID_PACKAGE_NAME=com.yourname.ballast

# A long random string. The app must send this as the `x-api-key` header.
# This backend holds bank access tokens — this key is what keeps it private.
API_KEY=change-me-to-a-long-random-string

PORT=8080
