# Copy this file to `.env` and fill in your values. NEVER commit .env.
# Get these from the Plaid dashboard: https://dashboard.plaid.com/developers/keys
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_sandbox_secret_here

# sandbox = fake test banks (free) | production = your real banks
PLAID_ENV=sandbox

# Must EXACTLY match `android.package` in app/app.json AND the
# "Allowed Android package names" list in the Plaid dashboard.
ANDROID_PACKAGE_NAME=io.github.s1vart.ballast

# Shared secret the app must send as the `x-api-key` header.
# REQUIRED, min 32 chars — the server refuses to start otherwise.
# Generate:  openssl rand -hex 32
API_KEY=

# Encrypts Plaid access_tokens at rest in data.json (AES-256-GCM).
# REQUIRED, exactly 64 hex chars. Losing it = relink your banks (tokens
# become undecryptable), so back it up with your password manager.
# Generate:  openssl rand -hex 32
DATA_KEY=

PORT=8080
# 0.0.0.0 = reachable from your LAN (needed for the phone-over-WiFi workflow).
# If you run a Cloudflare Tunnel on this machine, set HOST=127.0.0.1 instead.
HOST=0.0.0.0

# --- OPTIONAL: durable token store for cloud hosts (Koyeb) ---
# The cloud filesystem is ephemeral, so data.json is wiped on every redeploy.
# Set BOTH of these to a free Upstash Redis database (no credit card) and the
# encrypted token store is kept there instead — linked banks survive redeploys.
# Leave blank for local/Mac hosting (uses data.json on disk).
# Get them from https://console.upstash.com → your DB → "REST API".
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
