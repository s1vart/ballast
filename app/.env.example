# Copy to `app/.env`. EXPO_PUBLIC_* vars are inlined into the app at build time.
#
# NOTE: anything EXPO_PUBLIC_* ships inside the APK — someone with the APK file
# can extract these. Fine for a personal app that never leaves your phone;
# treat the key as burned (rotate it in server/.env) if you ever share the APK.
#
# Where your backend is reachable FROM THE PHONE/EMULATOR:
#   Android emulator  -> http://10.0.2.2:8080   (10.0.2.2 = the emulator's host machine)
#   iOS simulator     -> http://localhost:8080
#   Physical S25      -> http://<your-computer-LAN-IP>:8080   (e.g. http://192.168.1.20:8080)
#                        or a Cloudflare Tunnel URL (https) — see README
EXPO_PUBLIC_API_URL=http://10.0.2.2:8080

# Must match API_KEY in server/.env (generate with: openssl rand -hex 32).
# The app refuses to run with this placeholder left in place.
EXPO_PUBLIC_API_KEY=change-me-to-a-long-random-string
